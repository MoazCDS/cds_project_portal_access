<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_task_timesheet_form" inherit_id="project.portal_my_task">
        <!-- Insert after hr_timesheet's existing heading when timesheets exist -->
        <xpath expr="//h5[@id='task_timesheets']" position="after">
            <t t-if="can_log_timesheet and allow_timesheets">
                <form method="POST" t-attf-action="/my/tasks/#{task.id}/timesheet/add"
                      class="mb-3 border rounded p-2 bg-light">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="access_token" t-att-value="task.access_token"/>
                    <div class="row g-2 align-items-end">
                        <div class="col-12 col-sm-4">
                            <input type="text" name="name" class="form-control form-control-sm"
                                   placeholder="Description" required="required"/>
                        </div>
                        <div class="col-6 col-sm-3">
                            <input type="date" name="date" class="form-control form-control-sm"
                                   t-att-value="today"/>
                        </div>
                        <div class="col-6 col-sm-3">
                            <input type="number" name="unit_amount" class="form-control form-control-sm"
                                   step="0.01" min="0.01" required="required"
                                   t-att-placeholder="'Days' if is_uom_day else 'Hours'"/>
                        </div>
                        <div class="col-12 col-sm-2">
                            <button type="submit" class="btn btn-sm btn-primary w-100">
                                <i class="fa fa-plus me-1"/>
                                Log
                            </button>
                        </div>
                    </div>
                </form>
            </t>
        </xpath>

        <!-- Insert with own heading when hr_timesheet section is not shown -->
        <xpath expr="//div[@id='card_body']" position="inside">
            <t t-if="can_log_timesheet and allow_timesheets and not (timesheets and allow_timesheets and show_portal_timesheets)">
                <div class="container mt-3">
                    <h5 class="mt-2 mb-2">Timesheets</h5>
                    <form method="POST" t-attf-action="/my/tasks/#{task.id}/timesheet/add"
                          class="mb-3 border rounded p-2 bg-light">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="access_token" t-att-value="task.access_token"/>
                        <div class="row g-2 align-items-end">
                            <div class="col-12 col-sm-4">
                                <input type="text" name="name" class="form-control form-control-sm"
                                       placeholder="Description" required="required"/>
                            </div>
                            <div class="col-6 col-sm-3">
                                <input type="date" name="date" class="form-control form-control-sm"
                                       t-att-value="today"/>
                            </div>
                            <div class="col-6 col-sm-3">
                                <input type="number" name="unit_amount" class="form-control form-control-sm"
                                       step="0.01" min="0.01" required="required"
                                       t-att-placeholder="'Days' if is_uom_day else 'Hours'"/>
                            </div>
                            <div class="col-12 col-sm-2">
                                <button type="submit" class="btn btn-sm btn-primary w-100">
                                    <i class="fa fa-plus me-1"/>
                                    Log
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
